    "react-apexcharts": "^2.1.0",
    "react-aria": "^3.45.0",
    "react-aria-components": "^1.14.0",
    "react-calendar": "^6.0.0",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.22.0",
