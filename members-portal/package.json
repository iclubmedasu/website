{
    "name": "members-portal",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "clean:next": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\"",
        "build:fresh": "pnpm run clean:next && pnpm exec next build || pnpm exec next build",
        "start:fresh": "pnpm run build:fresh && next start --port 3001",
        "dev": "next dev --port 3001",
        "tsc": "tsc",
        "build": "next build",
        "start": "next start --port 3001",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "pwa:screenshots": "npx tsx scripts/capture-pwa-screenshots.ts"
    },
    "dependencies": {
        "@iclub/shared": "workspace:*",
        "apexcharts": "^5.10.4",
        "html2canvas": "^1.4.1",
        "jszip": "^3.10.1",
        "lucide-react": "^0.563.0",
        "next": "^15.0.0",
        "next-pwa": "^5.6.0",
        "react": "^19.0.0",
        "react-apexcharts": "^2.1.0",
        "react-calendar": "^6.0.0",
        "react-dom": "^19.0.0",
        "react-icons": "^5.6.0",
        "xlsx-js-style": "^1.2.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "babel-loader": "^10.1.1",
        "typescript": "^5.0.0"
    }
}