{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "strict": true,
        "declaration": true,
        "skipLibCheck": true,
        "rootDir": "./src",
        "outDir": "./dist"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "src/**/__tests__/**",
        "src/**/*.test.ts"
    ]
}
