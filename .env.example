# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string used by Prisma and backend runtime.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iclub

# ============================================
# AUTHENTICATION
# ============================================
# Secret key for signing JWT tokens. Use a strong random value (minimum 32 chars).
JWT_SECRET=replace-with-secure-random-secret-minimum-32-characters

# Cookie name used to store the auth token (httpOnly cookie).
AUTH_COOKIE_NAME=iclub_token

# ============================================
# APPLICATION
# ============================================
# Backend server port.
PORT=3000

# Runtime environment (development | test | production).
NODE_ENV=development

# Developer account email that gets developer-level access.
DEVELOPER_EMAIL=dev@yourorg.com

# Developer account password used by the seeded/developer login path.
DEVELOPER_PASSWORD=change-this-dev-password

# ============================================
# CORS / FRONTEND ORIGINS
# ============================================
# Comma-separated list of allowed frontend origins for backend CORS.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002

# Optional single frontend URL reference for deployment tooling/documentation.
# Note: backend currently reads FRONTEND_ORIGINS for CORS.
FRONTEND_URL=http://localhost:3001

# ============================================
# GITHUB FILE STORAGE (PROJECT FILES)
# ============================================
# GitHub owner/org for project file storage repository.
GITHUB_STORAGE_OWNER=your-org

# GitHub repository name used for project files.
GITHUB_STORAGE_REPO=your-repo

# Personal Access Token with repo scope for project file upload/download/delete.
GITHUB_STORAGE_TOKEN=ghp_yourtoken

# ============================================
# GITHUB USER DATA STORAGE (PROFILE PHOTOS)
# ============================================
# Personal Access Token with repo scope for user-data repository access.
GITHUB_USER_DATA_TOKEN=ghp_yourtoken

# GitHub owner/org for user-data repository.
GITHUB_USER_DATA_OWNER=your-org

# Repository name for member profile photos and user assets.
GITHUB_USER_DATA_REPO=user-data

# ============================================
# FRONTEND API ENDPOINTS
# ============================================
# Members portal API base URL (Vite frontend).
VITE_API_URL=http://localhost:3000/api

# Public website API base URL (Next.js frontend).
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================
# E2E TESTING (PLAYWRIGHT)
# ============================================
# Credentials used by Playwright auth smoke tests.
TEST_EMAIL=dev@iclub.com
TEST_PASSWORD=dev123456

# Optional: target an already running frontend URL for Playwright.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173

# Optional: port used by Playwright webServer when BASE_URL is not set.
PLAYWRIGHT_PORT=4173
