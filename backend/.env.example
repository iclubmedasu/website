###############################################################
# DATABASE
###############################################################
# Local db url (commented out)
# DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/iclubmedasu_db"
# Supabase db url
DATABASE_URL="[ACTUAL_DATABASE_URL_HERE]"
# For Github secret, use session pooler (5432) URL without `?pgbouncer=true`:
# When using the transaction pooler (6543) at runtime, Prisma needs to know it's behind a pooler. Update your deploy workflow's DATABASE_URL secret for HF to include: postgresql://postgres.ojnvasgdhfgrssoouuuf:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

###############################################################
# AUTHENTICATION
###############################################################
JWT_SECRET="[ACTUAL_JWT_SECRET_HERE]"
JWT_EXPIRES_IN="7d"

###############################################################
# APPLICATION (local dev)
###############################################################
PORT=3000
# PORT=7860 for HF Space Variables
NODE_ENV="development"

# Developer Backdoor (REMOVE IN PRODUCTION!)
DEVELOPER_EMAIL=[ACTUAL_EMAIL_HERE]
DEVELOPER_PASSWORD=[ACTUAL_PASSWORD_HERE]

###############################################################
# EMAIL (RESEND)
###############################################################
RESEND_API_KEY=[ACTUAL_RESEND_API_KEY_HERE]
# Must be a verified domain/sender in Resend (not @gmail.com). Use onboarding@resend.dev for local testing only.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optional: replies go to this address when using a Resend test sender
RESEND_REPLY_TO=asu.medicine.iclub@gmail.com

# Public website base URL (used in ticket email confirmation links)
# Local: http://localhost:3002 | Production HF: https://iclubmedasu-public-website.hf.space
PUBLIC_WEBSITE_URL=http://localhost:3002

###############################################################
# CORS / FRONTEND ORIGINS
###############################################################
FRONTEND_URL=https://iclubmedasu-members-portal.hf.space
# Comma-separated extra allowed browser origins (members portal, public website, previews)
FRONTEND_ORIGINS=https://iclubmedasu-members-portal.hf.space,https://iclubmedasu-public-website.hf.space

###############################################################
# GITHUB FILE STORAGE (PROJECT FILES)
###############################################################
GITHUB_STORAGE_OWNER=iclubmedasu
GITHUB_STORAGE_REPO=file-storage
GITHUB_STORAGE_TOKEN=[ACTUAL_TOKEN_HERE]

###############################################################
# GITHUB USER DATA STORAGE (PROFILE PHOTOS)
###############################################################
GITHUB_USER_DATA_OWNER=iclubmedasu
GITHUB_USER_DATA_REPO=user-data
GITHUB_USER_DATA_TOKEN=[ACTUAL_TOKEN_HERE]

###############################################################
# SUPABASE CONFIGURATION (informational — baked into DATABASE_URL)
###############################################################
SUPABASE_PROJECT_NAME=members-portal
SUPABASE_PROJECT_ID=ojnvasgdhfgrssoouuuf
SUPABASE_DB_PASSWORD=[ACTUAL_PASSWORD_HERE]

###############################################################
# HUGGING FACE DEPLOY / CI (not loaded by the running API)
###############################################################
HF_SPACE_URL=iclubmedasu-backend.hf.space
HF_TOKEN=[ACTUAL_TOKEN_HERE]
HF_SPACE=iclubmedasu/backend
HF_FRONTEND_SPACE=iclubmedasu/members-portal
HF_PUBLIC_SPACE=iclubmedasu/public-website
