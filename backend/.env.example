###############################################################
# DATABASE
###############################################################
# Local db url (commented out)
# DATABASE_URL="postgresql://postgres:goztir-karred-1dibRa@localhost:5432/iclubmedasu_db"
# Supabase db url
DATABASE_URL="[ACTUAL_DATABASE_URL_HERE]"
# For Github secret, use session pooler (5432) URL without `?pgbouncer=true`:
# When using the transaction pooler (6543) at runtime, Prisma needs to know it's behind a pooler. Update your deploy workflow's DATABASE_URL secret for HF to include: postgresql://postgres.ojnvasgdhfgrssoouuuf:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

###############################################################
# AUTHENTICATION
###############################################################
JWT_SECRET="[ACTUAL_JWT_SECRET_HERE]"
JWT_EXPIRES_IN="7d"

###############################################################
# APPLICATION
###############################################################
PORT=3000
NODE_ENV="development"

# Developer Backdoor (REMOVE IN PRODUCTION!)
DEVELOPER_EMAIL=[ACTUAL_EMAIL_HERE]
DEVELOPER_PASSWORD=[ACTUAL_PASSWORD_HERE]

###############################################################
# CORS / FRONTEND ORIGINS
###############################################################
# (add if needed, not present in .env)

###############################################################
# GITHUB FILE STORAGE (PROJECT FILES)
###############################################################
GITHUB_STORAGE_OWNER=iclubmedasu
GITHUB_STORAGE_REPO=file-storage
GITHUB_STORAGE_TOKEN=[ACTUAL_TOKEN_HERE]

###############################################################
# GITHUB USER DATA STORAGE (PROFILE PHOTOS)
###############################################################
GITHUB_USER_DATA_OWNER=iclubmedasu
GITHUB_USER_DATA_REPO=user-data
GITHUB_USER_DATA_TOKEN=[ACTUAL_TOKEN_HERE]

###############################################################
# SUPABASE CONFIGURATION
###############################################################
SUPABASE_PROJECT_NAME=members-portal
SUPABASE_PROJECT_ID=ojnvasgdhfgrssoouuuf
SUPABASE_DB_PASSWORD=[ACTUAL_PASSWORD_HERE]

###############################################################
# HUGGINGFACE CONFIGURATION
###############################################################
HF_TOKEN=[ACTUAL_TOKEN_HERE]
HF_SPACE=iclubmedasu/backend
